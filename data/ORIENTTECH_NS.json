0.6,271.95,112789]],"fundamentals":{"website":"https://www.orientindia.in","city":"Mumbai","full_time_employees":1432,"trailing_pe":51.555798,"price_to_book":3.092498,"book_value":77.688,"eps_trailing":4.66,"dividend_rate":3.6,"dividend_yield":1.0,"payout_ratio":0.0,"revenue":9461533696.0,"revenue_per_share":203.877,"revenue_growth":-0.033,"ebitda":562226752.0,"ebitda_margins":0.05942,"gross_margins":0.090450004,"operating_margins":-0.00209,"profit_margins":0.024300002,"net_income":229960000.0,"total_cash":731929984.0,"total_cash_per_share":15.997,"total_debt":218355008.0,"debt_to_equity":6.129,"enterprise_value":10479213568.0,"enterprise_to_ebitda":18.639,"enterprise_to_revenue":1.108,"shares_outstanding":45805916.0,"float_shares":12856873.0,"held_pct_insiders":0.70653,"held_pct_institutions":0.0,"fifty_two_week_high":466.72726,"fifty_two_week_low":238.75,"fifty_day_average":313.626,"two_hundred_day_avg":327.9235,"recommendation":"none","all_time_high":613.5,"all_time_low":224.59091,"long_business_summary":"Orient Technologies Limited provides information technology services in India and internationally. It operates through three segments, IT Infrastructure Products and Services, Cloud and Devops and Data Management Services, and ITES Services. It offers IT infrastructure services, such as infrastructure design and consulting services; turnkey systems integration and set up of network and data center infrastructure, including supply of associated equipment and software; private and public cloud, and software defined network and storage solutions; and network infrastructure design and setup for ISPs, VDI solutions, and onsite and remote facilities management of multi-location infrastructure. It also offers IaaS, PaaS, FaaS, DBaaS, storage as a service, network as a service, security as a service, backup as a service, monitoring as a service, software as a service, content delivery network, and serverless computing solutions; and enterprise IT services, including infrastructure managed, breakfix, managed print, cloud computing, systems integration, and applications development and maintenance services. In addition, the company offers managed services, such as monitoring, maintenance, and support of IT systems; multi-vendor support; network operations centre services; and renewals of software licenses. Further, it provides data centre solutions that include servers, storage, active, and passive networking components; collaboration solutions for CCTV, virtual conferences, and meetings; and security solutions; as well as hyper converged infrastructure; virtualization solutions; and end-user computing that include desktop management, end-user support, and mobile device management. It serves BFSI, media, communication, healthcare, ITeS, manufacturing, government, infrastructure, real estate, logistics, education, e-commerce, conglomerates, energy, and service industries. The company was incorporated in 1997 and is headquartered in Mumbai, India."}}