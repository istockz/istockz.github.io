],"fundamentals":{"long_name":"Aeonx Digital Technology Ltd","website":"https://www.aeonx.digital","city":"Mumbai","full_time_employees":251,"trailing_pe":35.356037,"price_to_book":0.99462616,"book_value":114.817,"eps_trailing":3.23,"dividend_rate":1.0,"dividend_yield":0.88,"payout_ratio":0.3096,"five_yr_avg_div_yield":0.62,"revenue":523424992.0,"revenue_per_share":114.521,"revenue_growth":0.868,"ebitda":-11436250.0,"ebitda_margins":-0.02185,"gross_margins":0.46738997,"operating_margins":-0.06892,"profit_margins":0.02849,"net_income":14912000.0,"total_cash":59228000.0,"total_cash_per_share":12.851,"total_debt":17315000.0,"debt_to_equity":3.269,"enterprise_value":484423840.0,"enterprise_to_ebitda":-42.359,"enterprise_to_revenue":0.925,"shares_outstanding":4600343.0,"float_shares":1350685.0,"held_pct_insiders":0.77555,"held_pct_institutions":0.0,"beta":-0.484,"fifty_two_week_high":242.0,"fifty_two_week_low":113.35,"fifty_day_average":138.805,"two_hundred_day_avg":176.4235,"recommendation":"none","all_time_high":310.0,"all_time_low":113.35,"long_business_summary":"Aeonx Digital Technology Limited operates as a software technology and cloud company in India and internationally. The company offers business solutions, including RISE with SAP for implementing SAP solutions; SAP SuccessFactors, a cloud-based software for human capital management; SAP Ariba, a connection solution; SAP BTP to unlock business potential; Big Data for delivery of actionable insights; SAP Mobility for enterprise mobile applications; DevOps, which combines software development and IT operations; and AMS for application maintenance of systems. It also provides OrderX, an internet facing web portal to facilitate order placing; SupplierX, a subscription-based portal; SignX, a tool to sign and approve digital data; DriveX, a file storage and retrieval solution; Xpense, an expense management tool; ScanX, a solution that helps push data scanned through a QR on SAP; AttendX, a cloud SAAS solution for contractual labour attendance; and AceX solution for day-to-day report and business insights. In addition, the company offers cloud solutions, such as SAP and Microsoft on AWS, disaster recovery, application modernization, Internet of Things, machine learning, industrial solution, and managed services. Further, it provides management, supply chain, cloud database, ERP support, application development, cloud and DevOps consultation, system integration, and education/training services, as well as trades in minerals. Additionally, the company offers implementation, support, migration, innovation, and staffing services. It serves the manufacturing, mining and minerals, logistics, chemicals, pharmaceuticals, healthcare, oil and gas, telecommunications, and retail industries. The company was formerly known as Ashok Alco-Chem Limited and changed its name to Aeonx Digital Technology Limited in December 2023. The company was incorporated in 1992 and is based in Mumbai, India. Aeonx Digital Technology Limited is a subsidiary of Aura Alkalies And Chemicals Private Limited."}}